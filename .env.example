# CRM webhook (Google Apps Script or any POST endpoint).
# Requests are sent with mode: no-cors so the server response is opaque —
# only network-level errors (no internet, DNS failure) are catchable client-side.
# Set this to a CORS-enabled proxy if you need confirmed delivery status.
VITE_CRM_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Google Analytics 4 — get Measurement ID from analytics.google.com → Admin → Data Streams
VITE_GA4_ID=G-XXXXXXXXXX
